# Billie CRM — local development environment template.
#
# Copy to .env and fill in real values. The actual .env file is git-ignored.
# All deployed environments (dev, demo, prod) set these via Fly secrets.

# -----------------------------------------------------------------------------
# Postgres (used by Payload's pg adapter on the Node side AND by asyncpg on
# the Python event-processor side — same DSN works for both).
#
# Local dev: point at your own Postgres (e.g. the billie-postgres docker
#   container, with a billie_crm role + database):
#     postgresql://billie_crm:<your-dev-password>@host.docker.internal:5432/billie_crm
#
# Neon (dev branch / staging / demo / prod): include sslmode=require — the
# processor refuses to start in production without it.
#     postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/billie_crm?sslmode=require
# -----------------------------------------------------------------------------
DATABASE_URI=postgresql://billie_crm:CHANGE_ME@host.docker.internal:5432/billie_crm

# -----------------------------------------------------------------------------
# Redis — stream + dedup. Use rediss:// in production.
# -----------------------------------------------------------------------------
REDIS_URL=redis://host.docker.internal:6383

# -----------------------------------------------------------------------------
# Payload — random secret for cookie signing. Generate per environment, e.g.:
#     openssl rand -hex 32
# -----------------------------------------------------------------------------
PAYLOAD_SECRET=replace-with-32-byte-hex-secret

# -----------------------------------------------------------------------------
# App URL — must match the scheme + host that the browser uses to reach the
# CRM, otherwise Payload's auth cookies won't be sent on subsequent requests.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://localhost:3000

# -----------------------------------------------------------------------------
# AWS — S3 for document storage. In dev we use the host's mounted SSO config.
# -----------------------------------------------------------------------------
# AWS_PROFILE=billie-dev
# AWS_REGION=ap-southeast-2

# -----------------------------------------------------------------------------
# NODE_ENV — leave unset for dev/test. Set to "production" in deployed envs;
# the event-processor enforces TLS + non-localhost DSNs when this is set.
# -----------------------------------------------------------------------------
# NODE_ENV=production
