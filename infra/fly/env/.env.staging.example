# =============================================================================
# Environment Secrets - STAGING
# =============================================================================
# SETUP:
#   1. Copy this file to .env.staging (in this directory)
#   2. Fill in the actual secret values
#   3. Run: make -C infra/fly secrets ENV=staging
#
# ⚠️  NEVER commit .env.staging to version control!
# =============================================================================

# Database (MongoDB Atlas)
DATABASE_URI=mongodb+srv://user:password@cluster.mongodb.net/billie-servicing

# Redis (Upstash)
REDIS_URL=redis://default:password@host.upstash.io:6379

# Payload CMS
PAYLOAD_SECRET=your-secret-key-change-in-production
